<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Status badge + action buttons on the invoice form -->
    <record id="view_move_form_clearvo" model="ir.ui.view">
        <field name="name">account.move.form.clearvo</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Status bar: add Clearvo status badge after the main status bar -->
            <xpath expr="//div[hasclass('o_statusbar_status')]" position="after">
                <div class="o_clearvo_status_bar d-flex align-items-center gap-2 ms-4"
                     attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}">

                    <span class="badge"
                          attrs="{
                            'invisible': [('clearvo_status', '=', 'not_sent')],
                            'class': {
                                'badge bg-secondary':  [('clearvo_status', '=', 'not_sent')],
                                'badge bg-warning text-dark': [('clearvo_status', 'in', ['pending', 'submitted'])],
                                'badge bg-success':    [('clearvo_status', '=', 'accepted')],
                                'badge bg-danger':     [('clearvo_status', 'in', ['rejected', 'error'])],
                            }
                          }">
                        <field name="clearvo_status" widget="badge"
                               decoration-warning="clearvo_status in ('pending', 'submitted')"
                               decoration-success="clearvo_status == 'accepted'"
                               decoration-danger="clearvo_status in ('rejected', 'error')"
                               decoration-muted="clearvo_status == 'not_sent'"/>
                    </span>

                    <!-- Retry button — shown only for errors -->
                    <button name="action_clearvo_retry"
                            string="Retry"
                            type="object"
                            icon="fa-refresh"
                            class="btn btn-sm btn-outline-secondary"
                            attrs="{'invisible': [('clearvo_status', 'not in', ['not_sent', 'error'])]}"/>

                    <!-- Open in Clearvo dashboard -->
                    <button name="action_clearvo_open_dashboard"
                            string="View in Clearvo"
                            type="object"
                            icon="fa-external-link"
                            class="btn btn-sm btn-outline-secondary"
                            attrs="{'invisible': [('clearvo_ref_id', '=', False)]}"/>
                </div>
            </xpath>

            <!-- Error detail in the chatter area / below the invoice -->
            <xpath expr="//field[@name='narration']" position="after">
                <div class="alert alert-danger mb-3"
                     attrs="{'invisible': [('clearvo_status', '!=', 'error')]}">
                    <strong>Clearvo submission failed</strong>
                    <p class="mb-0 mt-1 small"><field name="clearvo_error" readonly="1"/></p>
                    <button name="action_clearvo_retry"
                            string="Retry now"
                            type="object"
                            class="btn btn-sm btn-danger mt-2"/>
                </div>
            </xpath>

        </field>
    </record>

    <!-- Clearvo columns in the invoice list view -->
    <record id="view_invoice_list_clearvo" model="ir.ui.view">
        <field name="name">account.move.list.clearvo</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <field name="clearvo_status"
                       optional="show"
                       widget="badge"
                       decoration-warning="clearvo_status in ('pending', 'submitted')"
                       decoration-success="clearvo_status == 'accepted'"
                       decoration-danger="clearvo_status in ('rejected', 'error')"
                       decoration-muted="clearvo_status == 'not_sent'"/>
            </xpath>
        </field>
    </record>

</odoo>
