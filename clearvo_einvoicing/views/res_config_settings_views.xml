<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend res.config.settings to expose Clearvo company fields -->
    <record id="res_config_settings_view_form_clearvo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.clearvo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Insert after the Customer Invoices block -->
            <xpath expr="//block[@id='invoicing_settings']" position="after">
                <block title="Clearvo E-Invoicing" name="clearvo_settings_container">
                    <setting string="API Key"
                             help="Your Clearvo API key. Starts with csk_live_ for production or csk_test_ for sandbox.">
                        <div class="content-group">
                            <field name="clearvo_api_key"
                                   password="True"
                                   placeholder="csk_live_..."
                                   widget="char"
                                   class="w-100"/>
                            <button type="object"
                                    name="action_clearvo_open_wizard"
                                    string="Connect to Clearvo →"
                                    class="btn btn-sm btn-primary mt-2"
                                    invisible="clearvo_api_key != False"/>
                            <div class="mt-1" invisible="clearvo_api_key == False">
                                <span class="badge text-bg-success">Connected</span>
                            </div>
                        </div>
                    </setting>
                    <setting string="Auto-submit on post"
                             help="Automatically submit invoices to Clearvo when you confirm them. Disable to submit manually.">
                        <field name="clearvo_auto_submit"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
