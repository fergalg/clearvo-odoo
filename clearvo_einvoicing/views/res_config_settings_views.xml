<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend res.config.settings to expose Clearvo company fields -->
    <record id="res_config_settings_view_form_clearvo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.clearvo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='account_invoice']" position="after">
                <div id="clearvo_settings" class="app_settings_block">
                    <h2>Clearvo E-Invoicing</h2>
                    <div class="row mt16 o_settings_container">

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="clearvo_auto_submit"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="clearvo_auto_submit" string="Auto-submit on post"/>
                                <div class="text-muted">
                                    Submit invoices to Clearvo automatically when posted.
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label string="API Key"/>
                                <div class="text-muted mb-2">
                                    Your Clearvo API key (starts with
                                    <code>csk_live_</code> or <code>csk_test_</code>).
                                </div>
                                <field name="clearvo_api_key"
                                       password="True"
                                       placeholder="csk_live_..."
                                       widget="char"/>
                                <div class="mt-2">
                                    <button type="object"
                                            name="action_clearvo_open_wizard"
                                            string="Set up Clearvo →"
                                            class="btn btn-sm btn-primary"
                                            attrs="{'invisible': [('clearvo_api_key', '!=', False)]}"/>
                                    <span class="badge bg-success"
                                          attrs="{'invisible': [('clearvo_api_key', '=', False)]}">
                                        ✓ Connected
                                    </span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </xpath>
        </field>
    </record>


</odoo>
