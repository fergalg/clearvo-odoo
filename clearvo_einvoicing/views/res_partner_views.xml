<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Clearvo / Peppol tab to the partner form -->
    <record id="res_partner_view_form_clearvo" model="ir.ui.view">
        <field name="name">res.partner.view.form.clearvo</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Clearvo / Peppol" name="clearvo_peppol">
                    <group>
                        <group string="Peppol Endpoint">
                            <field name="clearvo_peppol_endpoint_id"
                                   placeholder="e.g. 0088:123456789 or 12345678"/>
                            <field name="clearvo_peppol_scheme_id"
                                   placeholder="e.g. 0088, 9915, 9917"/>
                        </group>
                        <group>
                            <div class="text-muted" colspan="2" style="font-size:12px; line-height:1.6">
                                <p><strong>Leave blank in most cases.</strong>
                                Clearvo derives the Peppol endpoint from the VAT number automatically.</p>
                                <p>Only set these fields if your buyer uses an identifier other than
                                their VAT number for Peppol — for example, a Dutch KvK number
                                (scheme 0088), an Austrian VAT (scheme 9915), or a Swiss UID (scheme 0183).
                                Your buyer's IT team can confirm the correct values.</p>
                            </div>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
